<% layout("/layouts/boilerplate") %>
<%
    const dashboardStats = {
        listingCount: stats && typeof stats.listingCount === "number" ? stats.listingCount : 0,
        reviewCount: stats && typeof stats.reviewCount === "number" ? stats.reviewCount : 0,
        averagePrice: stats && typeof stats.averagePrice === "number" ? stats.averagePrice : 0,
        bookingCount: stats && typeof stats.bookingCount === "number" ? stats.bookingCount : 0,
        bookingValue: stats && typeof stats.bookingValue === "number" ? stats.bookingValue : 0,
    };
    const bookings = Array.isArray(myBookings) ? myBookings : [];
%>

<section class="dashboard-hero">
    <div>
        <span class="eyebrow">Dashboard</span>
        <h1>Welcome back, <%= currUser.username %>.</h1>
        <p>Track your bookings, hosted places, review activity, and quick actions in one place.</p>
    </div>
    <a href="/listings/new" class="btn-primary-wl">
        <i class="fa-solid fa-plus"></i> Create place
    </a>
</section>

<section class="dashboard-stats">
    <div class="stat-card">
        <span>Your places</span>
        <strong><%= dashboardStats.listingCount %></strong>
    </div>
    <div class="stat-card">
        <span>Total reviews</span>
        <strong><%= dashboardStats.reviewCount %></strong>
    </div>
    <div class="stat-card">
        <span>Average price</span>
        <strong>&#8377;<%= dashboardStats.averagePrice.toLocaleString("en-IN") %></strong>
    </div>
    <div class="stat-card">
        <span>Bookings</span>
        <strong><%= dashboardStats.bookingCount %></strong>
    </div>
    <div class="stat-card">
        <span>Trip spend</span>
        <strong>&#8377;<%= dashboardStats.bookingValue.toLocaleString("en-IN") %></strong>
    </div>
</section>

<section class="dashboard-panel">
    <div class="page-header">
        <div>
            <span class="eyebrow">Your trips</span>
            <h2>Bookings</h2>
            <p class="section-subtle">Confirmed bookings appear here after you book a stay.</p>
        </div>
        <a href="/listings" class="btn-outline-wl">
            <i class="fa-solid fa-magnifying-glass"></i> Browse more
        </a>
    </div>

    <% if (bookings.length === 0) { %>
        <div class="empty-state">
            <div class="empty-icon"><i class="fa-solid fa-calendar-check"></i></div>
            <h3>No bookings yet</h3>
            <p>Book a stay from any listing and your trip details will show up here.</p>
            <a href="/listings" class="btn-primary-wl" style="margin-top:1.5rem;">Explore stays</a>
        </div>
    <% } else { %>
        <div class="dashboard-grid">
            <% for (let booking of bookings) { %>
                <% if (booking.listing) { %>
                    <article class="dashboard-card booking-dashboard-card">
                        <img src="<%= booking.listing.image %>" alt="<%= booking.listing.title %>" class="dashboard-card-image" />
                        <div class="dashboard-card-body">
                            <div class="dashboard-card-top">
                                <div>
                                    <h3><%= booking.listing.title %></h3>
                                    <p><i class="fa-solid fa-location-dot"></i> <%= booking.listing.location %>, <%= booking.listing.country %></p>
                                </div>
                                <span class="listing-pill"><%= booking.status %></span>
                            </div>

                            <div class="booking-dashboard-dates">
                                <div>
                                    <span>Check-in</span>
                                    <strong><%= new Date(booking.checkin).toLocaleDateString("en-IN", { day: "numeric", month: "short", year: "numeric" }) %></strong>
                                </div>
                                <div>
                                    <span>Checkout</span>
                                    <strong><%= new Date(booking.checkout).toLocaleDateString("en-IN", { day: "numeric", month: "short", year: "numeric" }) %></strong>
                                </div>
                            </div>

                            <div class="dashboard-meta">
                                <span><%= booking.nights %> night<%= booking.nights === 1 ? "" : "s" %></span>
                                <span>&#8377;<%= booking.total.toLocaleString("en-IN") %> total</span>
                            </div>

                            <div class="dashboard-actions">
                                <a href="/listings/<%= booking.listing._id %>" class="btn-outline-wl">
                                    <i class="fa-solid fa-eye"></i> View hotel
                                </a>
                            </div>
                        </div>
                    </article>
                <% } %>
            <% } %>
        </div>
    <% } %>
</section>

<section class="dashboard-panel">
    <div class="page-header">
        <div>
            <span class="eyebrow">Your portfolio</span>
            <h2>Hosted Places</h2>
            <p class="section-subtle">Everything you own, ordered from newest to oldest.</p>
        </div>
    </div>

    <% if (myListings.length === 0) { %>
        <div class="empty-state">
            <div class="empty-icon"><i class="fa-solid fa-house"></i></div>
            <h3>You have not created any places yet</h3>
            <p>Start with your first stay and it will show up here with edit and review summaries.</p>
            <a href="/listings/new" class="btn-primary-wl" style="margin-top:1.5rem;">Create your first place</a>
        </div>
    <% } else { %>
        <div class="dashboard-grid">
            <% for (let listing of myListings) { %>
                <article class="dashboard-card">
                    <img src="<%= listing.image %>" alt="<%= listing.title %>" class="dashboard-card-image" />
                    <div class="dashboard-card-body">
                        <div class="dashboard-card-top">
                            <div>
                                <h3><%= listing.title %></h3>
                                <p><i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %></p>
                            </div>
                            <span class="listing-pill"><%= listing.reviews.length %> review<%= listing.reviews.length === 1 ? "" : "s" %></span>
                        </div>

                        <p class="listing-description"><%= listing.description.slice(0, 120) %><%= listing.description.length > 120 ? "..." : "" %></p>

                        <div class="dashboard-meta">
                            <span>&#8377;<%= listing.price.toLocaleString("en-IN") %> / night</span>
                            <span>Created <%= new Date(listing.createdAt).toLocaleDateString("en-IN", { day: "numeric", month: "short", year: "numeric" }) %></span>
                        </div>

                        <div class="dashboard-actions">
                            <a href="/listings/<%= listing._id %>" class="btn-outline-wl">
                                <i class="fa-solid fa-eye"></i> View
                            </a>
                            <a href="/listings/<%= listing._id %>/edit" class="btn-primary-wl">
                                <i class="fa-solid fa-pen-to-square"></i> Edit
                            </a>
                        </div>
                    </div>
                </article>
            <% } %>
        </div>
    <% } %>
</section>
