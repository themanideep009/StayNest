<% layout("/layouts/boilerplate") %>

<section class="info-hero">
    <span class="eyebrow"><%= slug.charAt(0).toUpperCase() + slug.slice(1) %></span>
    <h1><%= page.title %></h1>
    <p><%= page.lead %></p>
</section>

<section class="info-grid">
    <% for (let section of page.sections) { %>
        <article class="info-card">
            <h2><%= section.heading %></h2>
            <p><%= section.body %></p>
        </article>
    <% } %>
</section>

<section class="cta-panel">
    <div>
        <span class="eyebrow">Next step</span>
        <h2>Keep exploring Stayhub.</h2>
        <p>Browse places, manage your own stays, or jump into the dashboard if you are already signed in.</p>
    </div>
    <div class="hero-actions">
        <a href="/listings" class="btn-primary-wl">
            <i class="fa-solid fa-globe"></i> Explore places
        </a>
        <% if (currUser) { %>
            <a href="/dashboard" class="btn-outline-wl">
                <i class="fa-solid fa-chart-line"></i> Dashboard
            </a>
        <% } else { %>
            <a href="/auth?mode=signup" class="btn-outline-wl">
                <i class="fa-solid fa-user-plus"></i> Join now
            </a>
        <% } %>
    </div>
</section>
