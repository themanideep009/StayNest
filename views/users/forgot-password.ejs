<% layout("/layouts/boilerplate") %>

<section class="form-card auth-utility-card">
    <h2><i class="fa-solid fa-key" style="color:var(--accent);margin-right:10px;"></i>Forgot Password</h2>
    <p class="section-subtle">Reset your password in three simple steps: request a code, verify it, then choose a new password.</p>

    <div class="auth-reset-steps">
        <div class="reset-step <%= resetStage === 'request' ? 'active' : '' %>">1. Request code</div>
        <div class="reset-step <%= resetStage === 'verify' ? 'active' : '' %>">2. Verify code</div>
        <div class="reset-step <%= resetStage === 'reset' ? 'active' : '' %>">3. Set password</div>
    </div>

    <form action="/forgot-password" method="POST" class="needs-validation" novalidate>
        <div class="wl-form-group">
            <label for="forgot-email">Email address</label>
            <input
                name="email"
                id="forgot-email"
                type="email"
                placeholder="you@example.com"
                value="<%= pendingResetEmail || '' %>"
                autocomplete="email"
                required
            />
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary-wl">
                <i class="fa-solid fa-paper-plane"></i> Send Verification Code
            </button>
            <a href="/auth?mode=login" class="btn-outline-wl">Back to Login</a>
        </div>
    </form>

    <% if (resetStage !== "request") { %>
    <form action="/forgot-password/verify" method="POST" class="needs-validation auth-code-panel" novalidate>
        <h3><i class="fa-solid fa-shield-heart" style="color:var(--highlight);margin-right:8px;"></i>Verify your code</h3>
        <p class="section-subtle">Enter the 6-digit PIN sent to your email to continue.</p>

        <div class="wl-form-group">
            <label for="verify-email">Email address</label>
            <input
                name="email"
                id="verify-email"
                type="email"
                placeholder="you@example.com"
                value="<%= typeof pendingResetEmail !== 'undefined' ? pendingResetEmail : '' %>"
                autocomplete="email"
                required
            />
        </div>

        <div class="wl-form-group">
            <label for="verify-code">Verification code</label>
            <input
                name="code"
                id="verify-code"
                type="text"
                inputmode="numeric"
                maxlength="6"
                placeholder="123456"
                required
            />
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary-wl">
                <i class="fa-solid fa-check"></i> Verify Code
            </button>
        </div>
    </form>
    <% } %>

    <% if (resetStage === "reset") { %>
    <form action="/reset-password" method="POST" class="needs-validation auth-code-panel" novalidate>
        <h3><i class="fa-solid fa-lock" style="color:var(--accent);margin-right:8px;"></i>Set your new password</h3>
        <p class="section-subtle">Your 6-digit PIN is verified. Now create a new password and sign back in securely.</p>

        <div class="wl-form-group">
            <label for="reset-password">New password</label>
            <input
                name="password"
                id="reset-password"
                type="password"
                placeholder="Enter a new password"
                autocomplete="new-password"
                required
            />
        </div>

        <div class="wl-form-group">
            <label for="reset-confirm-password">Confirm password</label>
            <input
                name="confirmPassword"
                id="reset-confirm-password"
                type="password"
                placeholder="Confirm your new password"
                autocomplete="new-password"
                required
            />
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary-wl">
                <i class="fa-solid fa-rotate"></i> Reset Password
            </button>
        </div>
    </form>
    <% } %>
</section>
