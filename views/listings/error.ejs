<% layout("/layouts/boilerplate") %>

<div class="error-wrapper">
    <div>
        <div class="error-code"><%= err.statusCode || 500 %></div>
        <div class="error-message"><%= err.message || "Something went wrong" %></div>
        <div class="error-sub">Oops! The page you're looking for doesn't exist or something broke.</div>
        <div class="error-actions">
            <a href="/listings" class="btn-primary-wl">
                <i class="fa-solid fa-arrow-left"></i> Back to Places
            </a>
        </div>
    </div>
</div>
