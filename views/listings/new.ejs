<% layout("/layouts/boilerplate") %>

<div class="form-card">
    <h2><i class="fa-solid fa-house-chimney-window" style="color:var(--accent);margin-right:10px;"></i>Create New Place</h2>

    <form method="POST" action="/listings" class="needs-validation" novalidate>

        <div class="wl-form-group">
            <label for="title">Title <span style="color:var(--accent);">*</span></label>
                <input
                    id="title"
                    name="listing[title]"
                    type="text"
                    placeholder="e.g. Cozy Beach House in Goa"
                    minlength="3"
                    required
                />
        </div>

        <div class="wl-form-group">
            <label for="description">Description <span style="color:var(--accent);">*</span></label>
            <textarea
                id="description"
                name="listing[description]"
                placeholder="Tell guests about your place..."
                minlength="10"
                required
            ></textarea>
        </div>

        <div class="wl-form-row">
            <div class="wl-form-group">
                <label for="price">Price per Night (₹) <span style="color:var(--accent);">*</span></label>
                <input
                    id="price"
                    name="listing[price]"
                    type="number"
                    placeholder="e.g. 2500"
                    min="0"
                    required
                />
            </div>
            <div class="wl-form-group">
                <label for="country">Country <span style="color:var(--accent);">*</span></label>
                <input
                    id="country"
                    name="listing[country]"
                    type="text"
                    placeholder="e.g. India"
                    required
                />
            </div>
        </div>

        <div class="wl-form-group">
            <label for="location">Location / City <span style="color:var(--accent);">*</span></label>
            <input
                id="location"
                name="listing[location]"
                type="text"
                placeholder="e.g. Anjuna, North Goa"
                required
            />
        </div>

        <div class="wl-form-group">
            <label for="image">Photo 1 URL <span style="color:var(--muted);font-weight:400;">(cover)</span></label>
                <input
                    id="image"
                    name="listing[image]"
                    type="url"
                    placeholder="https://example.com/photo.jpg"
                />
        </div>

        <div class="wl-form-row">
            <div class="wl-form-group">
                <label for="imageTwo">Photo 2 URL <span style="color:var(--muted);font-weight:400;">(optional)</span></label>
                <input
                    id="imageTwo"
                    name="listing[images][]"
                    type="url"
                    placeholder="https://example.com/room.jpg"
                />
            </div>
            <div class="wl-form-group">
                <label for="imageThree">Photo 3 URL <span style="color:var(--muted);font-weight:400;">(optional)</span></label>
                <input
                    id="imageThree"
                    name="listing[images][]"
                    type="url"
                    placeholder="https://example.com/view.jpg"
                />
            </div>
        </div>

        <div class="wl-form-row">
            <div class="wl-form-group">
                <label for="imageFour">Photo 4 URL <span style="color:var(--muted);font-weight:400;">(optional)</span></label>
                <input
                    id="imageFour"
                    name="listing[images][]"
                    type="url"
                    placeholder="https://example.com/lounge.jpg"
                />
            </div>
            <div class="wl-form-group">
                <label for="imageFive">Photo 5 URL <span style="color:var(--muted);font-weight:400;">(optional)</span></label>
                <input
                    id="imageFive"
                    name="listing[images][]"
                    type="url"
                    placeholder="https://example.com/balcony.jpg"
                />
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary-wl">
                <i class="fa-solid fa-plus"></i> Create Place
            </button>
            <a href="/listings" class="btn-outline-wl">Cancel</a>
        </div>
    </form>
</div>
