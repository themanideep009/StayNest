<% layout("/layouts/boilerplate") %>

<div class="form-card">
    <h2><i class="fa-solid fa-pen-to-square" style="color:var(--accent);margin-right:10px;"></i>Edit Place</h2>

    <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" class="needs-validation" novalidate>

        <div class="wl-form-group">
            <label for="title">Title <span style="color:var(--accent);">*</span></label>
            <input
                id="title"
                name="listing[title]"
                type="text"
                value="<%= listing.title %>"
                minlength="3"
                required
            />
        </div>

        <div class="wl-form-group">
            <label for="description">Description <span style="color:var(--accent);">*</span></label>
            <textarea
                id="description"
                name="listing[description]"
                minlength="10"
                required
            ><%= listing.description %></textarea>
        </div>

        <div class="wl-form-row">
            <div class="wl-form-group">
                <label for="price">Price per Night (₹) <span style="color:var(--accent);">*</span></label>
                <input
                    id="price"
                    name="listing[price]"
                    type="number"
                    value="<%= listing.price %>"
                    min="0"
                    required
                />
            </div>
            <div class="wl-form-group">
                <label for="country">Country <span style="color:var(--accent);">*</span></label>
                <input
                    id="country"
                    name="listing[country]"
                    type="text"
                    value="<%= listing.country %>"
                    required
                />
            </div>
        </div>

        <div class="wl-form-group">
            <label for="location">Location / City <span style="color:var(--accent);">*</span></label>
            <input
                id="location"
                name="listing[location]"
                type="text"
                value="<%= listing.location %>"
                required
            />
        </div>

        <div class="wl-form-group">
            <label for="image">Image URL</label>
            <input
                id="image"
                name="listing[image]"
                type="url"
                value="<%= listing.image %>"
            />
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary-wl">
                <i class="fa-solid fa-floppy-disk"></i> Save Changes
            </button>
            <a href="/listings/<%= listing._id %>" class="btn-outline-wl">Cancel</a>
        </div>
    </form>
</div>
