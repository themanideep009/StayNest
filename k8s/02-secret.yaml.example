apiVersion: v1
kind: Secret
metadata:
  name: staynest-secret
  namespace: staynest
type: Opaque
stringData:
  MONGO_URL: "mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/staynest"
  SESSION_SECRET: "replace-with-long-random-secret"
  JWT_SECRET: "replace-with-long-random-secret"
  GOOGLE_CLIENT_ID: ""
  GOOGLE_CLIENT_SECRET: ""
  GOOGLE_CALLBACK_URL: "https://staynest.example.com/auth/google/callback"
  TWILIO_ACCOUNT_SID: ""
  TWILIO_AUTH_TOKEN: ""
  TWILIO_VERIFY_SERVICE_SID: ""
  SMTP_HOST: ""
  SMTP_PORT: "587"
  SMTP_SECURE: "false"
  SMTP_USER: ""
  SMTP_PASS: ""
  EMAIL_FROM: ""
